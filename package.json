{
  "name": "@openfantasymap/maplibre-grid",
  "version": "1.0.0",
  "description": "Client-side square & hexagonal VTT grid generation for MapLibre GL JS. Define a grid by cell side length, rotation and one corner position.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "demo": "vite",
    "demo:build": "vite build"
  },
  "keywords": [
    "maplibre",
    "maplibre-gl",
    "grid",
    "hexgrid",
    "hexagonal",
    "vtt",
    "tabletop",
    "gis",
    "geojson"
  ],
  "license": "Apache-2.0",
  "author": "Open Fantasy Maps",
  "homepage": "https://github.com/openfantasymap/maplibre-grid#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openfantasymap/maplibre-grid.git"
  },
  "bugs": {
    "url": "https://github.com/openfantasymap/maplibre-grid/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "peerDependencies": {
    "maplibre-gl": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "maplibre-gl": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/geojson": "^7946.0.14",
    "maplibre-gl": "^4.7.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
